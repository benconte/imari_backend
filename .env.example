# ── Database ──────────────────────────────────────────────────────────────────
# Runtime connection (may go through PgBouncer pooler in production)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/imari_db

# CLI connection for Prisma migrate/introspect (bypasses pooler)
# For local Docker dev, set this equal to DATABASE_URL.
# For Neon production, use the non-pooled endpoint URL.
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/imari_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=<hex-64-chars>
JWT_REFRESH_SECRET=<hex-64-chars>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Encryption (AES-256-GCM for TOTP secrets) ─────────────────────────────────
ENCRYPTION_KEY=<hex-64-chars>

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_FROM=Imari <no-reply@imari.local>

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
THROTTLE_TTL=60
THROTTLE_LIMIT=100
